{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "nextjs", "vitest", "jsx-a11y", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "eslint/no-await-in-loop": "off"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true,
    "vitest/globals": true
  }
}
