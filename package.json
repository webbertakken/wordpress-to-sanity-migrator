{
  "name": "wordpress-to-sanity-migrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "node scripts/lint.mjs",
    "format": "prettier --write .",
    "typecheck": "tsgo --noEmit",
    "verify-studio": "node scripts/verify-studio.mjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "prettier --write",
      "oxlint --fix --quiet"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@sanity/client": "^7.22.0",
    "@sanity/types": "^5.22.0",
    "nanoid": "^5.1.9",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript/native-preview": "^7.0.0-dev.20260425.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "mysql2": "^3.22.2",
    "node-html-parser": "^7.1.0",
    "oxlint": "^1.61.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "vitest": "^4.1.5"
  },
  "volta": {
    "node": "24.14.1",
    "yarn": "4.9.2"
  },
  "packageManager": "yarn@4.9.2"
}
